<%- include('../partials/head', {title: 'Instructor Analytics - SeekoBharat'}) %>
<body>
    <%- include('../partials/navbar', {page: 'Student_Dashboard'}) %>


    <style>
        body {
            background-color: #f8f9fa;
            font-family: 'Arial', sans-serif;
        }

        .card {
            border-radius: 15px;
        }

        .card-header {
            background: linear-gradient(45deg, #00c6ff, #0072ff);
            color: white;
            font-weight: bold;
        }

        .card-body {
            background: white;
            border-radius: 15px;
        }

        .card-title {
            font-size: 1.5rem;
            color: #333;
        }

        .card-text {
            font-size: 1.2rem;
            color: #666;
        }

        h1, h3 {
            color: #333;
        }

        .metric-card {
            cursor: pointer;
            transition: transform 0.2s ease-in-out;
        }

        .metric-card:hover {
            transform: scale(1.05);
        }

        .chart-container {
            margin-top: 30px;
        }

        .footer {
            text-align: center;
            margin-top: 50px;
            color: #aaa;
        }

        .footer a {
            color: #0072ff;
            text-decoration: none;
        }

        .footer a:hover {
            text-decoration: underline;
        }
    </style>


    <div class="container mt-5">
        <h1 class="text-center mb-4">Instructor Analytics</h1>

        <div class="row">
            <!-- Total Revenue Card -->
            <div class="col-md-4">
                <div class="card metric-card shadow-lg">
                    <div class="card-header">Total Revenue</div>
                    <div class="card-body">
                        <h5 class="card-title">$<%= totalRevenue.toFixed(2) %></h5>
                        <p class="card-text">Total revenue from all your courses.</p>
                    </div>
                </div>
            </div>

            <!-- Revenue by Course Card -->
            <div class="col-md-4">
                <div class="card metric-card shadow-lg">
                    <div class="card-header">Revenue by Course</div>
                    <div class="card-body">
                        <h5 class="card-title">Detailed Revenue Breakdown</h5>
                        <p class="card-text">
                            <ul>
                                <% for (let course of courses) { %>
                                    <li><%= course.title %>: $<%= revenueByCourseName[course.title].toFixed(2) %></li>
                                <% } %>
                            </ul>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Course Completion Rates Card -->
            <div class="col-md-4">
                <div class="card metric-card shadow-lg">
                    <div class="card-header">Completion Rates</div>
                    <div class="card-body">
                        <h5 class="card-title">Student Completion Status</h5>
                        <p class="card-text">
                            <ul>
                                <% for (let completion of courseCompletionRates) { %>
                                    <li><%= completion.course %>: <%= (completion.completionRate * 100).toFixed(2) %>%</li>
                                <% } %>
                            </ul>
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div class="row chart-container">
            <!-- Revenue by Course Chart -->
            <div class="col-md-6">
                <h3>Revenue by Course (Bar Chart)</h3>
                <canvas id="revenueChart"></canvas>
            </div>

            <!-- Course Completion Rate Chart -->
            <div class="col-md-6">
                <h3>Course Completion Rates (Pie Chart)</h3>
                <canvas id="completionChart"></canvas>
            </div>
        </div>

        <!-- Footer with Link -->
        <div class="footer mt-5">
            <p>Powered by <a href="https://yourwebsite.com" target="_blank">Your Website</a></p>
        </div>

    </div>

    <!-- Bootstrap JS and dependencies -->
    <script src="https://cdn.jsdelivr.net/npm/@popperjs/core@2.11.6/dist/umd/popper.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.min.js"></script>

    <script>
        // Data for Revenue by Course Chart
        const revenueData = {
            labels: <%= JSON.stringify(courses.map(course => course.title)) %>,
            datasets: [{
                label: 'Revenue by Course',
                data: <%= JSON.stringify(courses.map(course => revenueByCourseName[course.title])) %>,
                backgroundColor: '#0072ff',
                borderColor: '#0056b3',
                borderWidth: 1
            }]
        };

        // Data for Completion Rates Chart
        const completionData = {
            labels: <%= JSON.stringify(courseCompletionRates.map(completion => completion.course)) %>,
            datasets: [{
                label: 'Completion Rate',
                data: <%= JSON.stringify(courseCompletionRates.map(completion => completion.completionRate * 100)) %>,
                backgroundColor: '#ff9f40',
                borderColor: '#e6892a',
                borderWidth: 1
            }]
        };

        // Create Revenue Bar Chart
        const ctxRevenue = document.getElementById('revenueChart').getContext('2d');
        const revenueChart = new Chart(ctxRevenue, {
            type: 'bar',
            data: revenueData,
            options: {
                responsive: true,
                scales: {
                    x: {
                        beginAtZero: true,
                        grid: {
                            color: "#f0f0f0"
                        }
                    },
                    y: {
                        beginAtZero: true,
                        grid: {
                            color: "#f0f0f0"
                        }
                    }
                },
                plugins: {
                    tooltip: {
                        backgroundColor: '#333',
                        titleColor: 'white',
                        bodyColor: 'white',
                        footerColor: 'white',
                    }
                }
            }
        });

        // Create Course Completion Pie Chart
        const ctxCompletion = document.getElementById('completionChart').getContext('2d');
        const completionChart = new Chart(ctxCompletion, {
            type: 'pie',
            data: completionData,
            options: {
                responsive: true,
                plugins: {
                    tooltip: {
                        backgroundColor: '#333',
                        titleColor: 'white',
                        bodyColor: 'white',
                        footerColor: 'white',
                    }
                }
            }
        });
    </script>
    

</body>